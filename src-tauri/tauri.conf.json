{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aether-GUI",
  "version": "0.2.0",
  "identifier": "com.cluvexstudio.aethergui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Aether-GUI",
        "width": 420,
        "height": 640,
        "resizable": false,
        "center": true,
        "decorations": false,
        "backgroundColor": "#0D0D0F"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["binaries/*"]
  }
}
